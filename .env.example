# Public values used by the Next.js server-rendered dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only values used by scripts/collect.ts.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GITHUB_TOKEN=your-local-short-lived-token
MAX_REPOSITORIES=500

# Optional AI enrichment for project content recognition.
# Keep model keys server-only. The collector skips this when disabled.
AI_PROJECT_INSIGHTS_ENABLED=false
AI_PROJECT_INSIGHTS_LIMIT=25
SENSENOVA_API_KEY=your-sensenova-api-key
SENSENOVA_BASE_URL=https://token.sensenova.cn/v1
SENSENOVA_MODEL=sensenova-6.7-flash-lite
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
